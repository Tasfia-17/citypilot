# ──────────────────────────────────────────────
# CityPilot — Environment Variables
# Copy this file to backend/.env and fill in values
# ──────────────────────────────────────────────

# ── Google / Gemini (REQUIRED) ────────────────
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here
# OR for Vertex AI:
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ── MongoDB Atlas (REQUIRED) ──────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
# Free M0 cluster works fine for development
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxx.mongodb.net/
MONGODB_DB=citypilot

# ── Elasticsearch (for local: http://localhost:9200) ──
ELASTIC_URL=https://your-cluster.es.io:443
ELASTIC_API_KEY=your_elastic_api_key
# The MCP URL is auto-derived from ELASTIC_URL + /_mcp

# ── Dynatrace ─────────────────────────────────
# Get from: https://xxx.live.dynatrace.com → Access Tokens
DYNATRACE_URL=https://your-tenant.live.dynatrace.com
DYNATRACE_API_TOKEN=dt0c01.xxx
# MCP URL is auto-derived from DYNATRACE_URL + /mcp

# ── Arize Phoenix ─────────────────────────────
# Get from: https://app.phoenix.arize.com
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/v1/traces
PHOENIX_API_KEY=your_phoenix_api_key

# ── Fivetran ──────────────────────────────────
# Get from: https://fivetran.com/account/settings/api
FIVETRAN_API_KEY=your_fivetran_api_key
FIVETRAN_API_SECRET=your_fivetran_api_secret
FIVETRAN_WEATHER_CONNECTOR_ID=
FIVETRAN_311_CONNECTOR_ID=
FIVETRAN_EVENTS_CONNECTOR_ID=

# ── Data Source APIs ──────────────────────────
# OpenWeatherMap: https://openweathermap.org/api (free tier: 1000 calls/day)
OPENWEATHER_API_KEY=your_openweather_api_key

# Ticketmaster Discovery: https://developer.ticketmaster.com
TICKETMASTER_API_KEY=your_ticketmaster_api_key

# NYC Open Data app token (optional, increases rate limit)
# Register at: https://data.cityofnewyork.us/profile/app_tokens
NYC_OPEN_DATA_APP_TOKEN=

# ── Frontend ──────────────────────────────────
# Mapbox: https://account.mapbox.com (free tier available)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiLi4uIn0...
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
